{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dispatch Message",
  "description": "Per-message JSON schema for dispatch-kit inbox. Ported from OmO team-core MessageSchema.",
  "type": "object",
  "required": ["id", "from", "to", "type", "timestamp", "content"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique message ID (UUID or timestamp-based)"
    },
    "from": {
      "type": "string",
      "description": "Sender role (e.g., 'controller', 'impl', 'test')"
    },
    "to": {
      "type": "string",
      "description": "Target role"
    },
    "type": {
      "type": "string",
      "enum": ["task_handoff", "evidence_handoff", "worker_result", "status_query", "cancel"],
      "description": "Message type — maps to templates/"
    },
    "timestamp": {
      "type": "number",
      "description": "Unix timestamp in milliseconds (for ordering)"
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "low"
    },
    "content": {
      "type": "object",
      "description": "Type-specific payload",
      "properties": {
        "goal": { "type": "string" },
        "scope": { "type": "object", "properties": { "touch": { "type": "string" }, "do_not_touch": { "type": "string" } } },
        "context": { "type": "string" },
        "acceptance": { "type": "string" },
        "status": { "type": "string", "enum": ["done", "blocked", "rejected", "in_progress"] },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "verification": { "type": "string" },
        "evidence_path": { "type": "string" },
        "next": { "type": "string" }
      }
    }
  }
}
